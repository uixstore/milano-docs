{
  "name": "milano-docs",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:md": "markdownlint-cli2",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{md,mdx}": [
      "prettier --write",
      "markdownlint-cli2 --fix"
    ],
    "*.{js,mjs,ts,cjs,json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@astrojs/starlight": "^0.39.2",
    "astro": "^6.3.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1"
  }
}
