{
  "config": {
    "default": true,
    "MD003": { "style": "atx" },
    "MD007": { "indent": 2 },
    "MD013": false,
    "MD024": { "siblings_only": true },
    "MD025": false,
    "MD033": false,
    "MD036": false,
